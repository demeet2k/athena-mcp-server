{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Voynich EVA Atom",
  "type": "object",
  "required": [
    "id",
    "kind",
    "source_unit",
    "evidence_class",
    "confidence",
    "docs_gate",
    "inputs",
    "transform",
    "outputs",
    "constraints",
    "export_targets",
    "source_refs",
    "symbol",
    "atom_class",
    "phoneme",
    "semantic_roles",
    "modern_process"
  ],
  "properties": {
    "id": {"type": "string"},
    "kind": {"type": "string", "enum": ["eva_atom"]},
    "source_unit": {"type": "string"},
    "evidence_class": {"type": "string", "enum": ["direct", "derived", "mixed", "uncertain"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "docs_gate": {"type": "string", "enum": ["BLOCKED", "LIVE", "UNKNOWN"]},
    "inputs": {"type": "array"},
    "transform": {"type": "object"},
    "outputs": {"type": "array"},
    "constraints": {"type": "object"},
    "export_targets": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "symbol": {"type": "string"},
    "atom_class": {"type": "string"},
    "phoneme": {"type": "string"},
    "semantic_roles": {"type": "array", "items": {"type": "string"}},
    "modern_process": {"type": "string"}
  },
  "additionalProperties": true
}
