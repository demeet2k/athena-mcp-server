{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Voynich Morpheme",
  "type": "object",
  "required": [
    "id",
    "kind",
    "source_unit",
    "evidence_class",
    "confidence",
    "docs_gate",
    "inputs",
    "transform",
    "outputs",
    "constraints",
    "export_targets",
    "source_refs",
    "surface",
    "morpheme_class",
    "meaning",
    "operator_family_ids",
    "source_ref_kind"
  ],
  "properties": {
    "id": {"type": "string"},
    "kind": {"type": "string", "enum": ["morpheme"]},
    "source_unit": {"type": "string"},
    "evidence_class": {"type": "string", "enum": ["direct", "derived", "mixed", "uncertain"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "docs_gate": {"type": "string", "enum": ["BLOCKED", "LIVE", "UNKNOWN"]},
    "inputs": {"type": "array"},
    "transform": {"type": "object"},
    "outputs": {"type": "array"},
    "constraints": {"type": "object"},
    "export_targets": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "surface": {"type": "string"},
    "morpheme_class": {"type": "string"},
    "meaning": {"type": "string"},
    "operator_family_ids": {"type": "array", "items": {"type": "string"}},
    "source_ref_kind": {"type": "string"}
  },
  "additionalProperties": true
}
