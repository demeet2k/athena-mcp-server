{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Voynich Operator Family",
  "type": "object",
  "required": [
    "id",
    "kind",
    "source_unit",
    "evidence_class",
    "confidence",
    "docs_gate",
    "inputs",
    "transform",
    "outputs",
    "constraints",
    "export_targets",
    "source_refs",
    "symbol",
    "family",
    "default_role",
    "token_families"
  ],
  "properties": {
    "id": {"type": "string"},
    "kind": {"type": "string", "enum": ["operator_family"]},
    "source_unit": {"type": "string"},
    "evidence_class": {"type": "string", "enum": ["direct", "derived", "mixed", "uncertain"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "docs_gate": {"type": "string", "enum": ["BLOCKED", "LIVE", "UNKNOWN"]},
    "inputs": {"type": "array"},
    "transform": {"type": "object"},
    "outputs": {"type": "array"},
    "constraints": {"type": "object"},
    "export_targets": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "symbol": {"type": "string"},
    "family": {"type": "string"},
    "default_role": {"type": "string"},
    "token_families": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
