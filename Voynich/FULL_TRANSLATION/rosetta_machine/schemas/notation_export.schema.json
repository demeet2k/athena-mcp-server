{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Voynich Notation Export",
  "type": "object",
  "required": [
    "id",
    "kind",
    "source_unit",
    "evidence_class",
    "confidence",
    "docs_gate",
    "inputs",
    "transform",
    "outputs",
    "constraints",
    "export_targets",
    "source_refs",
    "notation_id",
    "notation_class",
    "target_carrier",
    "source_record_id",
    "canonical_chain_digest",
    "program",
    "provenance"
  ],
  "properties": {
    "id": {"type": "string"},
    "kind": {"type": "string", "enum": ["notation_export"]},
    "source_unit": {"type": "string"},
    "evidence_class": {"type": "string", "enum": ["direct", "derived", "mixed", "uncertain"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "docs_gate": {"type": "string", "enum": ["BLOCKED", "LIVE", "UNKNOWN"]},
    "inputs": {"type": "array"},
    "transform": {"type": "object"},
    "outputs": {"type": "array"},
    "constraints": {"type": "object"},
    "export_targets": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "notation_id": {"type": "string"},
    "notation_class": {"type": "string"},
    "target_carrier": {"type": "string"},
    "source_record_id": {"type": "string"},
    "canonical_chain_digest": {"type": "string"},
    "description": {"type": "string"},
    "provenance": {"type": "object"}
  },
  "additionalProperties": true
}
