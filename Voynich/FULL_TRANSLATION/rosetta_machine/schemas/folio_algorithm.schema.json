{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Voynich Folio Algorithm",
  "type": "object",
  "required": [
    "id",
    "kind",
    "source_unit",
    "evidence_class",
    "confidence",
    "docs_gate",
    "inputs",
    "transform",
    "outputs",
    "constraints",
    "export_targets",
    "source_refs",
    "folio_id",
    "book_id",
    "book",
    "neural_node_id",
    "file_path",
    "purpose",
    "folio_zero_claim",
    "line_ids",
    "line_count",
    "token_count",
    "split_unit"
  ],
  "properties": {
    "id": {"type": "string"},
    "kind": {"type": "string", "enum": ["folio_algorithm"]},
    "source_unit": {"type": "string"},
    "evidence_class": {"type": "string", "enum": ["direct", "derived", "mixed", "uncertain"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "docs_gate": {"type": "string", "enum": ["BLOCKED", "LIVE", "UNKNOWN"]},
    "inputs": {"type": "array"},
    "transform": {"type": "object"},
    "outputs": {"type": "array"},
    "constraints": {"type": "object"},
    "export_targets": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "folio_id": {"type": "string"},
    "book_id": {"type": "string"},
    "book": {"type": "string"},
    "neural_node_id": {"type": "string"},
    "file_path": {"type": "string"},
    "purpose": {"type": "string"},
    "folio_zero_claim": {"type": "string"},
    "line_ids": {"type": "array", "items": {"type": "string"}},
    "line_count": {"type": "integer", "minimum": 0},
    "token_count": {"type": "integer", "minimum": 0},
    "split_unit": {"type": "boolean"}
  },
  "additionalProperties": true
}
