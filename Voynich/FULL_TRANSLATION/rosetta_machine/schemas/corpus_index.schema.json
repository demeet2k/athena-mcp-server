{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Voynich Corpus Index",
  "type": "object",
  "required": [
    "id",
    "kind",
    "source_unit",
    "evidence_class",
    "confidence",
    "docs_gate",
    "inputs",
    "transform",
    "outputs",
    "constraints",
    "export_targets",
    "source_refs",
    "source_document_count",
    "source_documents",
    "final_draft_folio_count",
    "line_operator_chain_count",
    "token_instance_count",
    "book_algorithm_count",
    "split_units",
    "book_counts",
    "neural_node_counts",
    "registry_counts",
    "docs_gate_required_files"
  ],
  "properties": {
    "id": {"type": "string"},
    "kind": {"type": "string", "enum": ["corpus_index"]},
    "source_unit": {"type": "string"},
    "evidence_class": {"type": "string", "enum": ["direct", "derived", "mixed", "uncertain"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "docs_gate": {"type": "string", "enum": ["BLOCKED", "LIVE", "UNKNOWN"]},
    "inputs": {"type": "array"},
    "transform": {"type": "object"},
    "outputs": {"type": "array"},
    "constraints": {"type": "object"},
    "export_targets": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "source_document_count": {"type": "integer", "minimum": 0},
    "source_documents": {"type": "array", "items": {"type": "object"}},
    "final_draft_folio_count": {"type": "integer", "minimum": 0},
    "line_operator_chain_count": {"type": "integer", "minimum": 0},
    "token_instance_count": {"type": "integer", "minimum": 0},
    "book_algorithm_count": {"type": "integer", "minimum": 0},
    "split_units": {"type": "array", "items": {"type": "string"}},
    "book_counts": {"type": "object"},
    "neural_node_counts": {"type": "object"},
    "registry_counts": {"type": "object"},
    "docs_gate_path": {"type": "string"},
    "docs_gate_required_files": {"type": "object"}
  },
  "additionalProperties": true
}
