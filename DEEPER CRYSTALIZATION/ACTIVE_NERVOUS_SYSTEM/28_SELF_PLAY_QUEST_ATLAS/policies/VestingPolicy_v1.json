        "VESTING_to_RELEASED": "truth_promotion_confirmed_OK",
        "LOCKED_to_FORFEITED": "truth_demotion_to_FAIL",
        "VESTING_to_FORFEITED": "truth_demotion_to_FAIL"
      }
    },
    "clamps": {
      "per_capsule_max": "16x BASE_XP (1024)",
      "per_epoch_max": "64x BASE_XP (4096)"
    }
  }
}
